# URL do Gateway (Kong)
EXPO_PUBLIC_BFF_URL=http://gateway.domestic.local
EXPO_PUBLIC_WS_URL=http://gateway.domestic.local

# Log Level: debug | info | warn | error | none
EXPO_PUBLIC_LOG_LEVEL=debug

# Error Tracking (Sentry)
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
EXPO_PUBLIC_SENTRY_ENABLED=true

# Analytics (Mixpanel - opcional)
# EXPO_PUBLIC_MIXPANEL_TOKEN=your-token

# Chaos Engineering (apenas dev)
EXPO_PUBLIC_SIMULATE_NETWORK=false
EXPO_PUBLIC_CHAOS_RATE=0.0
